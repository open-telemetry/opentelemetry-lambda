{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
    'helpers:pinGitHubActionDigestsToSemver',
    ':separateMultipleMajorReleases',
  ],
  prHourlyLimit: 15,
  prConcurrentLimit: 15,
  ignorePaths: [
    // re‑declare everything best-practices ignores
    "**/vendor/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/node_modules/**",
    "**/.cache/**",
  ],
  packageRules: [
    {
      labels: [
        'dependencies',
        'go',
      ],
      semanticCommitType: 'build',
      matchCategories: [
        'golang',
      ],
    },
    {
      labels: [
        'dependencies',
        'dotnet'
      ],
      semanticCommitType: 'build',
      matchCategories: [
        'dotnet'
      ],
    },
    {
      labels: [
        'dependencies',
        'java',
      ],
      semanticCommitType: 'build',
      matchCategories: [
        'java',
      ],
    },
    {
      labels: [
        'dependencies',
        'javascript',
      ],
      semanticCommitType: 'build',
      matchCategories: [
        'js',
      ],
    },
    {
      labels: [
        'dependencies',
        'python',
      ],
      semanticCommitType: 'build',
      matchCategories: [
        'python',
      ],
    },
    {
      labels: [
        'dependencies',
        'ruby',
      ],
      semanticCommitType: 'build',
      matchCategories: [
        'ruby',
      ],
    },
    {
      labels: [
        'dependencies',
        'github_actions',
      ],
      semanticCommitType: 'build',
      matchManagers: [
        'github-actions',
      ],
    },
    {
      groupName: 'collector-other',
      matchUpdateTypes: [
        '!major'
      ],
      matchCategories: [
        'golang',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'opentelemetry-deps-collector',
      matchUpdateTypes: [
        '!major'
      ],
      matchPackageNames: [
        'go.opentelemetry.io{/,}**',
        'github.com/open-telemetry{/,}**'
      ],
      matchCategories: [
        'golang',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'dotnet-other',
      matchUpdateTypes: [
        '!major'
      ],
      matchCategories: [
        'dotnet'
      ],
      schedule: [
        'before 8am on Monday'
      ],
    },
    {
      groupName: 'opentelemetry-deps-dotnet',
      matchUpdateTypes: [
        '!major'
      ],
      matchDepNames: [
        'OpenTelemetry.**'
      ],
      matchCategories: [
        'dotnet'
      ],
      schedule: [
        'before 8am on Monday'
      ],
    },
    {
      groupName: 'java-other',
      matchUpdateTypes: [
        '!major'
      ],
      matchCategories: [
        'java',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'opentelemetry-deps-java',
      matchUpdateTypes: [
        '!major'
      ],
      matchDepNames: [
        'io.opentelemetry.**',
      ],
      matchCategories: [
        'java',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'nodejs-other',
      matchUpdateTypes: [
        '!major'
      ],
      matchCategories: [
        'js',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'opentelemetry-deps-nodejs',
      matchUpdateTypes: [
        '!major'
      ],
      matchDepNames: [
        '@opentelemetry/**',
      ],
      matchCategories: [
        'js',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'python-other',
      matchUpdateTypes: [
        '!major'
      ],
      matchCategories: [
        'python',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'opentelemetry-deps-python',
      matchUpdateTypes: [
        '!major'
      ],
      matchDepNames: [
        'opentelemetry-**',
      ],
      matchCategories: [
        'python',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'ruby-other',
      matchUpdateTypes: [
        '!major'
      ],
      matchCategories: [
        'ruby',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'opentelemetry-deps-ruby',
      matchUpdateTypes: [
        '!major'
      ],
      matchDepNames: [
        'opentelemetry-**',
      ],
      matchCategories: [
        'ruby',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'actions',
      matchUpdateTypes: [
        '!major'
      ],
      matchManagers: [
        'github-actions',
      ],
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      matchUpdateTypes: [
        'major'
      ],
      matchManagers: [
        'github-actions',
      ],
      semanticCommitType: 'build',
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'docker',
      labels: [
        'dependencies',
        'docker',
      ],
      matchCategories: [
        'docker',
      ],
      semanticCommitType: 'build',
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      groupName: 'terraform',
      labels: [
        'dependencies',
        'terraform',
      ],
      matchCategories: [
        'terraform',
      ],
      semanticCommitType: 'build',
      schedule: [
        'before 8am on Monday',
      ],
    },
    {
      matchUpdateTypes: [
        'major'
      ],
      matchManagers: [
        '!github-actions',
      ],
      "dependencyDashboardApproval": true,
    },
  ],
  lockFileMaintenance: {
    enabled: true,
    schedule: [
      'before 8am on Wednesday',
    ],
  },
  postUpdateOptions: [
		"gomodTidy"
	],
  semanticCommits: 'enabled',
  semanticCommitType: 'build',
  semanticCommitScope: 'deps',
  labels: [
    'dependencies',
  ],
}
